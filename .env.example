# Copy to ".env" on the VPS and fill in. (compose reads .env automatically.)

# Contact the OSRS Wiki can reach if the collector misbehaves (their API requires one).
OSRS_GE_USER_AGENT=osrs-ge-terminal/0.1 (contact: brian@swp360.com)

# Dashboard login.
DASH_USER=brian
# Generate the hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'YOUR-PASSWORD'
# Paste the result below exactly as printed (no escaping needed).
DASH_HASH=REPLACE_WITH_BCRYPT_HASH
