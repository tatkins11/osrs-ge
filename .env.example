# Copy to ".env" on the VPS and fill in. (compose reads .env automatically.)

# Public address of the dashboard: your droplet IP for now (keep the "https://"),
# or a domain later. Caddy reads this and picks the cert automatically (domain ->
# trusted Let's Encrypt; bare IP -> self-signed) — no Caddyfile edit needed.
SITE_ADDRESS=https://YOUR_DROPLET_IP

# Contact the OSRS Wiki can reach if the collector misbehaves (their API requires one).
OSRS_GE_USER_AGENT=osrs-ge-terminal/0.1 (contact: tristan@swp360.com)

# Dashboard login.
DASH_USER=tristan
# Generate the hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'YOUR-PASSWORD'
# Paste it below but DOUBLE every "$"  ($2a$14$... -> $$2a$$14$$...) so Docker
# Compose treats it as literal text, not variables. (DEPLOY.md automates this.)
DASH_HASH=REPLACE_WITH_BCRYPT_HASH
