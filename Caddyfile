# Served on the address in SITE_ADDRESS. Caddy picks the cert automatically:
#   - a hostname (e.g. mybox.example.com, or 159-203-178-90.sslip.io) -> a free,
#     browser-TRUSTED Let's Encrypt certificate (no warning, works through
#     corporate SSL inspection).
#   - a bare IP or localhost -> a self-signed cert (encrypted, but browsers warn
#     and strict networks reject it).

{$SITE_ADDRESS} {
	encode zstd gzip

	# The RuneLite plugin POSTs live GE offers to /api/ge-offers; that path is
	# protected by its own bearer token (OSRS_GE_INGEST_TOKEN) in the app, so it
	# skips dashboard basic-auth. Everything else still requires login.
	@protected not path /api/ge-offers
	basic_auth @protected {
		{$DASH_USER} {$DASH_HASH}
	}

	reverse_proxy api:8000
}
