# Served on the address in SITE_ADDRESS (your droplet IP for now, e.g.
# https://203.0.113.5 — or a domain later).
#
# `tls internal` = a self-signed certificate: traffic is encrypted, but the
# browser shows a one-time "not trusted" warning you click past.
#
# When you get a real domain: set SITE_ADDRESS=your-domain.com in .env and
# DELETE the `tls internal` line below — Caddy then fetches a free, trusted
# Let's Encrypt certificate automatically (no more browser warning).

{$SITE_ADDRESS} {
	tls internal
	encode zstd gzip

	basic_auth {
		{$DASH_USER} {$DASH_HASH}
	}

	reverse_proxy api:8000
}
